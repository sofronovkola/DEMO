<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DEMO.AllUserControl.MainUC"
             xmlns:uc="clr-namespace:DEMO.AllUserControl"
             xmlns:vm="using:DEMO.AllUserControl"
             Name="MUControl"
             x:DataType="vm:MainUC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ListBox Name="ProdustListB" 
        Grid.Row="1" 
        ItemsSource="{Binding ProductList}"
        SelectionChanged="ProductListBox_OnSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Image Width="100"
                               Height="100"
                               Source="{Binding ImagePath}"/>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Category}"/>
                                <TextBlock>|</TextBlock>
                                <TextBlock Text="{Binding NameProductNavigation.NameProduct}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock TextWrapping="Wrap">Описание товара:</TextBlock>
                                <TextBlock Text="{Binding Description}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>Производитель:</TextBlock>
                                <TextBlock Text="{Binding Manufacturer}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>Поставщик:</TextBlock>
                                <TextBlock Text="{Binding Supplier}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>Цена:</TextBlock>
                                <TextBlock Text="{Binding Price}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>Ед.изм.:</TextBlock>
                                <TextBlock Text="{Binding ProductUnit}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>Количество на складе:</TextBlock>
                                <TextBlock Text="{Binding CountInStock}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16" Text="{Binding Discount}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Name="ButtonPanel" 
        HorizontalAlignment="Center" 
        Grid.Row="2" 
        Orientation="Horizontal">

            <Button Name="AddButton"  >Добавить</Button>
            <Button Name="EditButton" >Изменить</Button>
            <Button Name="RemoveButton" >Удалить</Button>
        </StackPanel>

<StackPanel Height="40" Name="SearchPanel" Orientation="Horizontal">
    <ComboBox Name="ManufacturersCBox" ItemsSource="{Binding manufacturer1}" DisplayMemberBinding="{Binding Manufacturer1}"></ComboBox>
    <TextBox Name="SearchTextB"></TextBox>
    <RadioButton Name="SortUpButton">по возрастанию</RadioButton>
    <RadioButton Name="SortDownButton">по убыванию</RadioButton>
    <Button Name="ResetButton">Сброс</Button>
</StackPanel>

    </Grid>
</UserControl>

<!--<Button Name="AddButton" Click="AddButton_OnClick" >Добавить</Button>
            <Button Name="EditButton" Click="EditButton_OnClick">Изменить</Button>
            <Button Name="RemoveButton" Click= "DeleteButton_OnClick">Удалить</Button>-->