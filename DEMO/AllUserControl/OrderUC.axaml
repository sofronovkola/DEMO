<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DEMO.AllUserControl.OrderUC">

 <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

         <ListBox Name="OrderListBox" 
         Grid.Row="1" 
         ItemsSource="{Binding OrderList}"
         SelectionChanged="ProductListBox_OnSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Vertical">
                        
                          <TextBlock Text= "{Binding IdOrder}"></TextBlock>
                          <TextBlock Text= "{Binding AddressNavigation.Index}"></TextBlock>
                          <TextBlock Text= "{Binding DateOrder,StringFormat={}{0:MM/dd/yyyy}}"></TextBlock>

                        </StackPanel>
                        <StackPanel>
                            <TextBlock FontSize="16" Text="{Binding DateDelvery,StringFormat={}{0:MM/dd/yyyy}}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <StackPanel Name="ButtonPanel" 
        HorizontalAlignment="Center" 
        Grid.Row="2" 
        Orientation="Horizontal">

          <Button Name="AddButton" Click="AddButton_OnClick" >Добавить</Button>
            <Button Name="EditButton" Click="EditButton_OnClick">Изменить</Button>
            <Button Name="RemoveButton" Click= "DeleteButton_OnClick">Удалить</Button>
        </StackPanel>

</Grid>

</UserControl>
